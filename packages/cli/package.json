{
  "name": "@compilerai/cli",
  "version": "1.0.0",
  "description": "Official CompilerAI CLI — intelligent business workflow compilation from the terminal",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "compiler": "./dist/cli.js"
  },
  "files": ["dist", "completions", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test --import tsx --test-reporter spec tests/**/*.test.ts",
    "cli": "tsx src/cli.ts"
  },
  "dependencies": {
    "@compilerai/sdk-typescript": "file:../sdk-typescript"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.19.0"
  },
  "engines": {
    "node": ">=20"
  }
}
